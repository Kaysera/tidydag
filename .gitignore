# -----------------------------------------------------------------------------
# 📁 PYTHON: compiled files, environments, caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.so
*.pyd
*.pyo
*.pyc

# Virtual environments
.venv/
venv/

# Python dependency lock files (used by uv, pip-tools, etc.)
.requirements

# -----------------------------------------------------------------------------
# 📁 CDK & AWS: context, output, credentials
# -----------------------------------------------------------------------------
cdk.context.json
cdk.out/

# AWS credentials (never commit real ones!)
credentials.json
*.pem

# CloudFormation-related envs
.env.cloudformation

# -----------------------------------------------------------------------------
# 📁 NODE & JAVASCRIPT: dependencies, builds, logs
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn-error.log

# Optional build artifacts (adjust for your CDK + JS tooling)
core/build/
core/**/*.c
core/**/*.so

# -----------------------------------------------------------------------------
# 🧪 TESTING & COVERAGE
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.hypothesis/

# -----------------------------------------------------------------------------
# 🧑‍💻 IDEs & EDITORS
# -----------------------------------------------------------------------------
.idea/
.vscode/

# -----------------------------------------------------------------------------
# 📓 JUPYTER NOTEBOOKS
# -----------------------------------------------------------------------------
**/*.ipynb
**/.ipynb_checkpoints/
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# 🧾 ENVIRONMENT FILES
# -----------------------------------------------------------------------------
.env*
!.env.example

# -----------------------------------------------------------------------------
# 🗃️ SYSTEM & OS FILES
# -----------------------------------------------------------------------------
*.DS_Store*

# -----------------------------------------------------------------------------
# LLM AND ASSISTED TOOLS FILES
# -----------------------------------------------------------------------------
AGENTS.md
GEMINI.md
.opencode/
.agents/
